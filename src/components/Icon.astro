const iconSvg = icons[name];

if (!iconSvg) {
  console.warn(
    `Icon "${name}" not found. Available icons:`,
    Object.keys(icons).join(", "),
  );
}
---

{
  iconSvg && (
    <span
      class={`c-icon c-icon--${size} ${className || ""}`}
      aria-label={label}
      role={label ? "img" : "presentation"}
      set:html={iconSvg}
    />
  )
}
